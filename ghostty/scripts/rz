#!/usr/bin/env ruby

require "fileutils"
require "json"
require "open3"
require "pathname"
require "rbconfig"
require "securerandom"
require "shellwords"
require "time"

class Rz
  SNAPSHOT_VERSION = 1
  TIMESTAMP_FORMAT = "%Y%m%d-%H%M%S"
  BOX_WIDTH = 92
  NAME_PATTERN = /\A[a-zA-Z0-9][a-zA-Z0-9._-]*\z/
  INTERVAL_PATTERN = /\A(\d+(?:\.\d+)?)([smh]?)\z/i
  MINIMUM_WATCH_INTERVAL = 10
  UUID_PATTERN = /[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/i

  def initialize(argv)
    @argv = argv.dup
    @home = Dir.home
    @script_dir = File.expand_path(__dir__)
    @state_root = File.expand_path(
      ENV.fetch("RZ_STATE_DIR", File.join(@home, ".local", "state", "ghostty-rz"))
    )
    @snapshots_dir = File.join(@state_root, "snapshots")
    @watchers_dir = File.join(@state_root, "watchers")
  end

  def run
    if @argv.first == "--save"
      options = parse_save_arguments(@argv.drop(1))
      save(**options)
    elsif @argv.first == "--watch"
      start_watch(parse_watch_arguments(@argv.drop(1)))
    elsif @argv == ["--watch-status"]
      watch_status
    elsif @argv == ["--watch-stop"]
      stop_watch
    elsif @argv.first == "--watch-worker"
      run_watch_worker(@argv.drop(1))
    elsif @argv == ["--help"]
      puts usage
    elsif @argv.length == 2 && @argv.first == "--session"
      restore(@argv.last, dry_run: false)
    elsif @argv.length == 3 && @argv.include?("--session") && @argv.include?("--dry-run")
      selector = @argv[@argv.index("--session") + 1]
      restore(selector, dry_run: true)
    elsif @argv == ["--dry-run"]
      restore(nil, dry_run: true)
    elsif @argv == ["--list"]
      list
    elsif @argv.empty?
      restore(nil, dry_run: false)
    else
      print_box("USAGE", usage.lines(chomp: true), io: $stderr)
      exit 64
    end
  rescue Interrupt
    print_box("INTERRUPTED", ["No changes were completed."], io: $stderr)
    exit 130
  rescue StandardError => error
    print_box("ERROR", [error.message], io: $stderr)
    exit 1
  end

  private

  def usage
    <<~TEXT
      Usage:
        rz --save NAME
        rz --save NAME [--no-scrollback] [--current-window]
        rz --watch NAME --every INTERVAL [--current-window | --all-windows]
        rz --watch-status
        rz --watch-stop
        rz
        rz --session NAME_OR_TIMESTAMP
        rz --session NAME_OR_TIMESTAMP --dry-run
        rz --dry-run
        rz --list
    TEXT
  end

  def parse_save_arguments(arguments)
    name = arguments.shift
    raise "missing snapshot name" unless name

    options = {
      name: name,
      capture_scrollback: true,
      current_window: false,
      window_id: nil
    }

    until arguments.empty?
      option = arguments.shift
      case option
      when "--no-scrollback"
        options[:capture_scrollback] = false
      when "--current-window"
        options[:current_window] = true
      when "--window-id"
        options[:window_id] = arguments.shift || raise("missing value for --window-id")
      else
        raise "unknown save option #{option.inspect}"
      end
    end

    if options[:current_window] && options[:window_id]
      raise "use either --current-window or --window-id, not both"
    end

    options
  end

  def parse_watch_arguments(arguments)
    name = arguments.shift
    raise "missing watcher snapshot name" unless name

    interval = nil
    scope = "current-window"
    until arguments.empty?
      option = arguments.shift
      case option
      when "--every"
        interval = parse_interval(arguments.shift || raise("missing value for --every"))
      when "--current-window"
        scope = "current-window"
      when "--all-windows"
        scope = "all-windows"
      else
        raise "unknown watcher option #{option.inspect}"
      end
    end

    raise "missing --every INTERVAL" unless interval

    {name: name, interval_seconds: interval, scope: scope}
  end

  def parse_interval(value)
    match = INTERVAL_PATTERN.match(value)
    raise "invalid interval #{value.inspect}; use seconds, minutes, or hours such as 30s, 15m, or 1h" unless match

    multiplier = {"" => 1, "s" => 1, "m" => 60, "h" => 3600}.fetch(match[2].downcase)
    seconds = (Float(match[1]) * multiplier).round
    raise "watch interval must be at least #{MINIMUM_WATCH_INTERVAL} seconds" if seconds < MINIMUM_WATCH_INTERVAL

    seconds
  end

  def save(name:, capture_scrollback:, current_window: false, window_id: nil)
    validate_name!(name)
    ensure_ghostty_running!

    target_window_id = window_id
    target_window_id ||= current_ghostty_window_id if current_window

    timestamp = Time.now.strftime(TIMESTAMP_FORMAT)
    snapshot_id = "#{name}_#{timestamp}"
    FileUtils.mkdir_p(@snapshots_dir)
    final_dir = File.join(@snapshots_dir, snapshot_id)
    raise "snapshot already exists: #{snapshot_id}" if File.exist?(final_dir)

    staging_dir = File.join(@snapshots_dir, ".#{snapshot_id}.#{Process.pid}.tmp")
    FileUtils.mkdir_p(File.join(staging_dir, "scrollback"))

    begin
      rows = capture_ghostty(capture_scrollback: capture_scrollback, window_id: target_window_id)
      if rows.empty? && target_window_id
        raise "Ghostty window #{target_window_id.inspect} is no longer available"
      end
      raise "Ghostty has no restorable terminal surfaces" if rows.empty?

      process_sessions = running_codex_sessions
      assignments, warnings = assign_codex_sessions(rows, process_sessions)
      unless rows.group_by { |row| row["window_index"] }.values.all? { |window_rows| window_geometry?(window_rows.first) }
        warnings << "window geometry unavailable; grant your shell Accessibility permission"
      end
      assignments.each { |terminal_id, session| terminal_row(rows, terminal_id)["codex"] = session }

      rows.each do |row|
        source = row.delete("scrollback_path")
        next if source.nil? || source.empty? || !File.file?(source)

        relative = File.join(
          "scrollback",
          format("window-%02d-tab-%02d-terminal-%02d.txt", row["window_index"], row["tab_index"], row["terminal_index"])
        )
        FileUtils.cp(source, File.join(staging_dir, relative))
        row["scrollback_file"] = relative
      end

      detected_sessions = target_window_id ? assignments.values : process_sessions
      snapshot = build_snapshot(
        name,
        snapshot_id,
        timestamp,
        rows,
        detected_sessions,
        warnings,
        capture_scrollback: capture_scrollback,
        target_window_id: target_window_id
      )
      File.write(File.join(staging_dir, "state.json"), JSON.pretty_generate(snapshot) + "\n")
      FileUtils.mv(staging_dir, final_dir)

      lines = [
        labeled("SNAPSHOT", snapshot_id),
        labeled("SCOPE", target_window_id ? "Ghostty window #{target_window_id}" : "all Ghostty windows"),
        labeled("LAYOUT", layout_summary(snapshot)),
        labeled("CONTENT", content_summary(assignments.length, rows.count { |row| row["scrollback_file"] }, capture_scrollback: capture_scrollback)),
        labeled("LOCATION", final_dir)
      ]
      warnings.each { |warning| lines << labeled("WARNING", warning) }
      print_box("WORKSPACE SAVED", lines)
    rescue StandardError
      FileUtils.rm_rf(staging_dir) if staging_dir.start_with?(@snapshots_dir + File::SEPARATOR)
      raise
    end
  end

  def restore(selector, dry_run:)
    snapshot_dir = resolve_snapshot(selector)
    snapshot = JSON.parse(File.read(File.join(snapshot_dir, "state.json")))
    validate_snapshot!(snapshot)

    if dry_run
      print_restore_preview(snapshot, snapshot_dir)
      return
    end

    running_ids = running_codex_sessions.filter_map { |session| session["session_id"] }.uniq
    script, duplicate_ids = restore_applescript(snapshot, snapshot_dir, running_ids)
    if ENV["RZ_PRINT_APPLESCRIPT"] == "1"
      puts script
      return
    end
    output = run_command("osascript", "-e", script)

    lines = [
      labeled("SNAPSHOT", snapshot.fetch("id")),
      labeled("LAYOUT", layout_summary(snapshot)),
      labeled("STATUS", "Restored into new Ghostty window(s)")
    ]
    duplicate_ids.each do |id|
      lines << labeled("WARNING", "Codex session already running; opened a shell: #{id}")
    end
    lines << labeled("GHOSTTY", output) unless output.empty?
    print_box("WORKSPACE RESTORED", lines)
  end

  def list
    snapshots = snapshot_directories
    if snapshots.empty?
      print_box("SAVED WORKSPACES", ["No snapshots found.", labeled("LOCATION", @snapshots_dir)])
      return
    end

    lines = snapshots.reverse_each.with_index(1).flat_map do |directory, index|
      state = JSON.parse(File.read(File.join(directory, "state.json")))
      [
        format("%02d  %s", index, state.fetch("id")),
        "    #{display_time(state.fetch("saved_at"))}  |  #{layout_summary(state)}"
      ]
    end
    lines << ""
    lines << labeled("LOCATION", @snapshots_dir)
    print_box("SAVED WORKSPACES", lines)
  end

  def start_watch(options)
    worker_pid = nil
    validate_name!(options.fetch(:name))
    ensure_ghostty_running!

    owner_pid = Process.ppid
    owner_started_at = process_start_marker(owner_pid)
    raise "could not identify the owning shell" if owner_started_at.empty?

    FileUtils.mkdir_p(@watchers_dir)
    state_path = watch_state_path(owner_pid)
    existing = read_watch_state(state_path)
    if existing && watcher_alive?(existing)
      raise "this shell already owns watcher #{existing.fetch("name").inspect}; run rz --watch-status"
    end
    FileUtils.rm_f(state_path)

    window_id = options.fetch(:scope) == "current-window" ? current_ghostty_window_id : nil
    token = SecureRandom.hex(16)
    log_path = File.join(@watchers_dir, "shell-#{owner_pid}.log")
    worker_arguments = [
      "--watch-worker",
      token,
      options.fetch(:name),
      options.fetch(:interval_seconds).to_s,
      owner_pid.to_s,
      owner_started_at,
      options.fetch(:scope),
      window_id || "-",
      state_path
    ]

    log = File.open(log_path, "a")
    worker_pid = Process.spawn(
      RbConfig.ruby,
      File.expand_path(__FILE__),
      *worker_arguments,
      in: File::NULL,
      out: log,
      err: log,
      pgroup: true
    )
    Process.detach(worker_pid)
    log.close

    state = {
      "version" => 1,
      "token" => token,
      "name" => options.fetch(:name),
      "interval_seconds" => options.fetch(:interval_seconds),
      "scope" => options.fetch(:scope),
      "window_id" => window_id,
      "owner_pid" => owner_pid,
      "owner_started_at" => owner_started_at,
      "worker_pid" => worker_pid,
      "started_at" => Time.now.iso8601,
      "log_path" => log_path
    }.compact
    write_watch_state(state_path, state)

    lines = [
      labeled("NAME", options.fetch(:name)),
      labeled("EVERY", display_interval(options.fetch(:interval_seconds))),
      labeled("SCOPE", window_id ? "bound to Ghostty window #{window_id}" : "all Ghostty windows"),
      labeled("MODE", "fast snapshots; scrollback skipped"),
      labeled("OWNER", "shell PID #{owner_pid}; watcher stops when this shell exits"),
      labeled("LOG", log_path)
    ]
    print_box("WATCHER STARTED", lines)
  rescue StandardError
    log&.close unless log&.closed?
    begin
      Process.kill("TERM", worker_pid) if worker_pid && process_alive?(worker_pid)
    rescue Errno::ESRCH
      nil
    end
    raise
  end

  def watch_status
    state_path = watch_state_path(Process.ppid)
    state = read_watch_state(state_path)
    unless state && watcher_alive?(state)
      FileUtils.rm_f(state_path)
      print_box("WATCHER STATUS", ["No active watcher belongs to this shell."])
      return
    end

    lines = [
      labeled("STATUS", "running"),
      labeled("NAME", state.fetch("name")),
      labeled("EVERY", display_interval(state.fetch("interval_seconds"))),
      labeled("SCOPE", watch_scope_label(state)),
      labeled("WORKER", "PID #{state.fetch("worker_pid")}"),
      labeled("STARTED", display_time(state.fetch("started_at"))),
      labeled("LAST SAVE", state["last_success_at"] ? display_time(state["last_success_at"]) : "pending"),
      labeled("SNAPSHOT", state["last_snapshot_id"] || "pending"),
      labeled("NEXT SAVE", state["next_attempt_at"] ? display_time(state["next_attempt_at"]) : "pending"),
      labeled("LAST ERROR", state["last_error"] || "none"),
      labeled("LOG", state.fetch("log_path"))
    ]
    print_box("WATCHER STATUS", lines)
  end

  def stop_watch
    state_path = watch_state_path(Process.ppid)
    state = read_watch_state(state_path)
    unless state && watcher_alive?(state)
      FileUtils.rm_f(state_path)
      print_box("WATCHER STOPPED", ["No active watcher belonged to this shell."])
      return
    end

    worker_pid = Integer(state.fetch("worker_pid"))
    Process.kill("TERM", worker_pid)
    deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + 5
    while process_alive?(worker_pid) && Process.clock_gettime(Process::CLOCK_MONOTONIC) < deadline
      sleep 0.1
    end

    if process_alive?(worker_pid)
      print_box("WATCHER STOP REQUESTED", [labeled("WORKER", "PID #{worker_pid}"), labeled("LOG", state.fetch("log_path"))])
    else
      FileUtils.rm_f(state_path)
      print_box("WATCHER STOPPED", [labeled("NAME", state.fetch("name")), labeled("WORKER", "PID #{worker_pid}")])
    end
  end

  def run_watch_worker(arguments)
    token, name, interval_value, owner_value, owner_started_at, scope, raw_window_id, state_path = arguments
    raise "malformed watcher worker arguments" unless state_path

    interval_seconds = Integer(interval_value, 10)
    owner_pid = Integer(owner_value, 10)
    window_id = raw_window_id == "-" ? nil : raw_window_id
    validate_name!(name)
    raise "invalid watcher token" unless token.match?(/\A[0-9a-f]{32}\z/)
    raise "invalid watcher interval" if interval_seconds < MINIMUM_WATCH_INTERVAL
    raise "invalid watcher scope" unless %w[current-window all-windows].include?(scope)
    raise "current-window watcher is missing its bound window ID" if scope == "current-window" && !window_id
    raise "all-windows watcher cannot have a bound window ID" if scope == "all-windows" && window_id
    raise "invalid watcher state path" unless File.expand_path(state_path) == watch_state_path(owner_pid)

    stop_requested = false
    %w[HUP INT TERM].each { |signal| Signal.trap(signal) { stop_requested = true } }

    sleep 0.1
    while !stop_requested && owner_alive?(owner_pid, owner_started_at)
      attempted_at = Time.now.iso8601
      update_watch_state(state_path, token, "last_attempt_at" => attempted_at, "last_error" => nil)

      save_arguments = ["--save", name, "--no-scrollback"]
      save_arguments.concat(["--window-id", window_id]) if window_id
      success = system(RbConfig.ruby, File.expand_path(__FILE__), *save_arguments)
      completed_at = Time.now
      updates = if success
        {
          "last_success_at" => completed_at.iso8601,
          "last_snapshot_id" => newest_snapshot_id(name),
          "last_error" => nil,
          "next_attempt_at" => (completed_at + interval_seconds).iso8601
        }
      else
        {
          "last_error" => "save failed at #{completed_at.iso8601}; see watcher log",
          "next_attempt_at" => (completed_at + interval_seconds).iso8601
        }
      end
      update_watch_state(state_path, token, updates)

      break unless wait_for_watch_interval(interval_seconds, owner_pid, owner_started_at) { stop_requested }
    end
  ensure
    remove_watch_state(state_path, token) if state_path && token
  end

  def watch_state_path(owner_pid)
    File.join(@watchers_dir, "shell-#{owner_pid}.json")
  end

  def read_watch_state(path)
    JSON.parse(File.read(path))
  rescue Errno::ENOENT, JSON::ParserError
    nil
  end

  def write_watch_state(path, state)
    FileUtils.mkdir_p(File.dirname(path))
    temporary = "#{path}.#{Process.pid}.tmp"
    File.write(temporary, JSON.pretty_generate(state) + "\n")
    File.rename(temporary, path)
  ensure
    FileUtils.rm_f(temporary) if temporary && File.exist?(temporary)
  end

  def update_watch_state(path, token, updates)
    state = read_watch_state(path)
    return unless state && state["token"] == token

    write_watch_state(path, state.merge(updates))
  end

  def remove_watch_state(path, token)
    state = read_watch_state(path)
    FileUtils.rm_f(path) if state && state["token"] == token
  end

  def watcher_alive?(state)
    worker_pid = Integer(state.fetch("worker_pid"))
    owner_pid = Integer(state.fetch("owner_pid"))
    owner_alive?(owner_pid, state.fetch("owner_started_at")) &&
      process_alive?(worker_pid) &&
      process_command(worker_pid).include?(state.fetch("token"))
  rescue ArgumentError, KeyError, TypeError
    false
  end

  def owner_alive?(pid, started_at)
    process_alive?(pid) && process_start_marker(pid) == started_at
  end

  def process_alive?(pid)
    Process.kill(0, pid)
    true
  rescue Errno::ESRCH
    false
  rescue Errno::EPERM
    true
  end

  def process_start_marker(pid)
    output, status = Open3.capture2e("ps", "-p", pid.to_s, "-o", "lstart=")
    status.success? ? output.strip : ""
  end

  def process_command(pid)
    output, status = Open3.capture2e("ps", "-ww", "-p", pid.to_s, "-o", "command=")
    status.success? ? output.strip : ""
  end

  def wait_for_watch_interval(seconds, owner_pid, owner_started_at)
    deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + seconds
    loop do
      return false if yield
      return false unless owner_alive?(owner_pid, owner_started_at)

      remaining = deadline - Process.clock_gettime(Process::CLOCK_MONOTONIC)
      return true if remaining <= 0

      sleep [remaining, 5].min
    end
  end

  def newest_snapshot_id(name)
    directory = snapshot_directories.reverse_each.find do |candidate|
      JSON.parse(File.read(File.join(candidate, "state.json"))).fetch("name") == name
    rescue JSON::ParserError, KeyError
      false
    end
    directory && File.basename(directory)
  end

  def display_interval(seconds)
    seconds = Integer(seconds)
    return "#{seconds / 3600}h" if (seconds % 3600).zero?
    return "#{seconds / 60}m" if (seconds % 60).zero?

    "#{seconds}s"
  end

  def watch_scope_label(state)
    state["window_id"] ? "Ghostty window #{state.fetch("window_id")}" : "all Ghostty windows"
  end

  def validate_name!(name)
    return if NAME_PATTERN.match?(name)

    raise "invalid snapshot name #{name.inspect}; use letters, numbers, dot, underscore, or dash"
  end

  def ensure_ghostty_running!
    run_command("osascript", "-e", 'tell application "Ghostty" to get version')
  rescue StandardError
    raise "Ghostty must be running to save a snapshot"
  end

  def current_ghostty_window_id
    script = 'tell application "Ghostty" to return id of first window as text'
    window_id = run_command("osascript", "-e", script).strip
    raise "Ghostty has no current window" if window_id.empty?

    window_id
  end

  def capture_ghostty(capture_scrollback:, window_id: nil)
    command = ["osascript", File.join(@script_dir, "snapshot-capture.applescript")]
    command << "--no-scrollback" unless capture_scrollback
    command.concat(["--window-id", window_id]) if window_id
    output = run_command(*command)
    lines = output.lines.map(&:chomp).reject(&:empty?)
    header = lines.shift&.split("\t", -1)
    expected = %w[
      window_index window_id window_name window_x window_y window_width window_height
      tab_index tab_id tab_name tab_selected terminal_index terminal_id terminal_name
      terminal_focused working_directory scrollback_path
    ]
    raise "unexpected Ghostty capture format" unless header == expected

    lines.map do |line|
      values = line.split("\t", -1)
      values << "" if values.length == expected.length - 1
      raise "malformed Ghostty capture row" unless values.length == expected.length

      row = expected.zip(values).to_h
      %w[window_index tab_index terminal_index].each { |key| row[key] = Integer(row[key], 10) }
      %w[window_x window_y window_width window_height].each do |key|
        row[key] = row[key].empty? ? nil : Integer(row[key], 10)
      end
      %w[tab_selected terminal_focused].each { |key| row[key] = row[key].casecmp?("true") }
      row
    end
  end

  def running_codex_sessions
    output = run_command("ps", "-axo", "pid=,tty=,command=")
    output.lines.filter_map do |line|
      line = line.chomp
      match = line.match(/\A\s*(\d+)\s+(\S+)\s+(.+)\z/)
      next unless match

      pid = Integer(match[1], 10)
      tty = match[2]
      command = match[3]
      next unless command.include?("/bin/codex")
      next if command.include?("codex-code-mode-host")
      next if command.start_with?("node ")

      cwd = process_cwd(pid)
      session_id = command[/\bresume\s+(#{UUID_PATTERN})/, 1] || newest_open_session_id(pid)
      next unless cwd && session_id

      {
        "pid" => pid,
        "tty" => tty,
        "cwd" => cwd,
        "session_id" => session_id,
        "command" => command
      }
    end
  end

  def process_cwd(pid)
    output, status = Open3.capture2e("lsof", "-nP", "-a", "-p", pid.to_s, "-d", "cwd", "-Fn")
    return unless status.success?

    output.lines.find { |line| line.start_with?("n/") }&.delete_prefix("n")&.chomp
  end

  def newest_open_session_id(pid)
    output, status = Open3.capture2e("lsof", "-nP", "-p", pid.to_s)
    return unless status.success?

    files = output.lines.filter_map do |line|
      path = line[/\s(\/.*rollout-[^ ]+-(#{UUID_PATTERN})\.jsonl)\s*\z/, 1]
      next unless path && File.file?(path)

      [File.mtime(path), path]
    end
    path = files.max_by(&:first)&.last
    path && File.basename(path)[UUID_PATTERN]
  end

  def assign_codex_sessions(rows, sessions)
    assignments = {}
    warnings = []

    sessions.group_by { |session| session["cwd"] }.each do |cwd, cwd_sessions|
      cwd_rows = rows.select { |row| row["working_directory"] == cwd }
      candidates = cwd_rows.select { |row| codex_title?(row["terminal_name"], cwd) }
      candidates += (cwd_rows - candidates) if candidates.length < cwd_sessions.length
      candidates = candidates.first(cwd_sessions.length)

      sorted_sessions = cwd_sessions.sort_by { |session| tty_number(session["tty"]) }
      if candidates.length < sorted_sessions.length
        warnings << "could not place every Codex session in #{cwd}; unplaced sessions will not auto-resume"
      end

      candidates.zip(sorted_sessions).each do |row, session|
        next unless row && session

        assignments[row["terminal_id"]] = session
      end
    end

    [assignments, warnings]
  end

  def codex_title?(title, cwd)
    basename = File.basename(cwd)
    first = title.each_codepoint.first
    title.include?("Action Required") ||
      title.downcase.include?("codex") ||
      title == basename ||
      title.end_with?("| #{basename}") ||
      (first && first.between?(0x2800, 0x28ff))
  end

  def tty_number(tty)
    tty[/\d+\z/]&.to_i || 1_000_000
  end

  def terminal_row(rows, terminal_id)
    rows.find { |row| row["terminal_id"] == terminal_id } || raise("missing terminal #{terminal_id}")
  end

  def build_snapshot(name, snapshot_id, timestamp, rows, process_sessions, warnings, capture_scrollback:, target_window_id: nil)
    windows = rows.group_by { |row| row["window_index"] }.sort.map do |window_index, window_rows|
      first_window_row = window_rows.first
      tabs = window_rows.group_by { |row| row["tab_index"] }.sort.map do |tab_index, tab_rows|
        first_tab_row = tab_rows.first
        {
          "index" => tab_index,
          "id" => first_tab_row["tab_id"],
          "name" => first_tab_row["tab_name"],
          "selected" => first_tab_row["tab_selected"],
          "terminals" => tab_rows.sort_by { |row| row["terminal_index"] }.map do |row|
            {
              "index" => row["terminal_index"],
              "id" => row["terminal_id"],
              "name" => row["terminal_name"],
              "focused" => row["terminal_focused"],
              "working_directory" => row["working_directory"],
              "scrollback_file" => row["scrollback_file"],
              "codex_session_id" => row.dig("codex", "session_id")
            }.compact
          end
        }
      end

      {
        "index" => window_index,
        "id" => first_window_row["window_id"],
        "name" => first_window_row["window_name"],
        "position" => window_position(first_window_row),
        "size" => window_size(first_window_row),
        "tabs" => tabs
      }.compact
    end

    {
      "version" => SNAPSHOT_VERSION,
      "name" => name,
      "id" => snapshot_id,
      "saved_at" => Time.now.iso8601,
      "timestamp" => timestamp,
      "ghostty_version" => ghostty_version,
      "tabs_count" => windows.sum { |window| window["tabs"].length },
      "terminals_count" => rows.length,
      "scrollback_captured" => capture_scrollback,
      "scope" => target_window_id ? {"type" => "window", "window_id" => target_window_id} : {"type" => "all_windows"},
      "windows" => windows,
      "detected_codex_sessions" => process_sessions,
      "warnings" => warnings,
      "limitations" => [
        "Ghostty does not expose split geometry; terminal counts restore as right-hand splits.",
        capture_scrollback ?
          "Scrollback restores as plain text output, without original styling or interactive state." :
          "Scrollback was intentionally skipped for this fast snapshot.",
        "Only Codex conversations are resumed; arbitrary child processes are not reconstructible."
      ]
    }
  end

  def ghostty_version
    run_command("osascript", "-e", 'tell application "Ghostty" to get version').strip
  end

  def snapshot_directories
    return [] unless Dir.exist?(@snapshots_dir)

    Dir.children(@snapshots_dir).filter_map do |entry|
      next if entry.start_with?(".")

      directory = File.join(@snapshots_dir, entry)
      next unless File.directory?(directory) && File.file?(File.join(directory, "state.json"))

      directory
    end.sort_by do |directory|
      state = JSON.parse(File.read(File.join(directory, "state.json")))
      [state.fetch("saved_at"), state.fetch("id")]
    rescue JSON::ParserError, KeyError
      ["", File.basename(directory)]
    end
  end

  def resolve_snapshot(selector)
    snapshots = snapshot_directories
    raise "no saved sessions; create one with rz --save NAME" if snapshots.empty?
    return snapshots.last if selector.nil?

    exact = snapshots.find { |directory| File.basename(directory) == selector }
    return exact if exact

    matching = snapshots.select do |directory|
      state = JSON.parse(File.read(File.join(directory, "state.json")))
      state["name"] == selector || state["timestamp"] == selector
    end
    raise "no saved session matches #{selector.inspect}; run rz --list" if matching.empty?

    matching.last
  end

  def validate_snapshot!(snapshot)
    raise "unsupported snapshot version #{snapshot["version"].inspect}" unless snapshot["version"] == SNAPSHOT_VERSION
    raise "snapshot has no windows" unless snapshot["windows"].is_a?(Array) && !snapshot["windows"].empty?
  end

  def print_restore_preview(snapshot, snapshot_dir)
    ids = snapshot.fetch("windows").flat_map { |window| window.fetch("tabs") }.flat_map { |tab| tab.fetch("terminals") }.filter_map { |terminal| terminal["codex_session_id"] }
    lines = [
      labeled("STATUS", "Dry run - Ghostty will not be changed"),
      labeled("SNAPSHOT", snapshot.fetch("id")),
      labeled("SAVED", "#{display_time(snapshot.fetch("saved_at"))}  |  Ghostty #{snapshot.fetch("ghostty_version")}"),
      labeled("LAYOUT", layout_summary(snapshot)),
      labeled("CODEX", ids.empty? ? "none" : "#{ids.length} session(s)"),
      labeled("LOCATION", snapshot_dir)
    ]
    ids.each { |id| lines << "              #{id}" }
    snapshot.fetch("limitations", []).each { |limitation| lines << labeled("NOTE", limitation) }
    print_box("RESTORE PREVIEW", lines)
  end

  def layout_summary(snapshot)
    "#{snapshot.fetch("windows").length} window(s)  |  #{snapshot.fetch("tabs_count")} tab(s)  |  #{terminal_count(snapshot)} terminal(s)"
  end

  def content_summary(codex_count, scrollback_count, capture_scrollback:)
    scrollback = capture_scrollback ? "#{scrollback_count} scrollback file(s)" : "scrollback skipped"
    "#{codex_count} Codex session(s)  |  #{scrollback}"
  end

  def display_time(value)
    Time.iso8601(value).strftime("%Y-%m-%d %H:%M:%S %:z")
  rescue ArgumentError
    value
  end

  def labeled(label, value)
    format("%-11s  %s", label, value)
  end

  def print_box(title, lines, io: $stdout)
    inner_width = BOX_WIDTH - 4
    border = "+#{"-" * (BOX_WIDTH - 2)}+"

    io.puts border
    io.puts box_line("RZ :: #{title}", inner_width)
    io.puts border
    lines.each do |line|
      wrap_line(line.to_s, inner_width).each { |part| io.puts box_line(part, inner_width) }
    end
    io.puts border
  end

  def box_line(text, width)
    "| #{text.ljust(width)} |"
  end

  def wrap_line(text, width)
    return [""] if text.empty?

    continuation = if text.match?(/\A[A-Z][A-Z ]{0,10}\s{2}/)
      " " * 13
    else
      text[/\A\s+/].to_s
    end
    lines = []
    remaining = text.dup
    first_line = true

    until remaining.empty?
      prefix = first_line ? "" : continuation
      available = width - prefix.length
      if remaining.length <= available
        lines << prefix + remaining
        break
      end

      break_at = remaining.rindex(" ", available)
      break_at = available if break_at.nil? || break_at < (available / 2)
      lines << prefix + remaining.slice!(0, break_at).rstrip
      remaining = remaining.lstrip
      first_line = false
    end

    lines
  end

  def terminal_count(snapshot)
    snapshot.fetch("windows").sum do |window|
      window.fetch("tabs").sum { |tab| tab.fetch("terminals").length }
    end
  end

  def restore_applescript(snapshot, snapshot_dir, running_ids)
    lines = ['tell application "Ghostty"', "activate"]
    duplicates = []
    final_focus = nil

    snapshot.fetch("windows").each_with_index do |window, window_offset|
      window_number = window_offset + 1
      window_var = "rzWindow#{window_number}"
      selected_tab_var = nil

      window.fetch("tabs").each_with_index do |tab, tab_offset|
        tab_number = tab_offset + 1
        terminals = tab.fetch("terminals")
        next if terminals.empty?

        first_config = "rzConfig#{window_number}_#{tab_number}_1"
        append_configuration(lines, first_config, terminals.first, snapshot_dir, running_ids, duplicates)

        tab_var = "rzTab#{window_number}_#{tab_number}"
        if tab_offset.zero?
          lines << "set #{window_var} to new window with configuration #{first_config}"
          lines << "set #{tab_var} to selected tab of #{window_var}"
        else
          lines << "set #{tab_var} to new tab in #{window_var} with configuration #{first_config}"
        end

        terminal_vars = ["rzTerminal#{window_number}_#{tab_number}_1"]
        lines << "set #{terminal_vars.first} to focused terminal of #{tab_var}"

        terminals.drop(1).each_with_index do |terminal, terminal_offset|
          terminal_number = terminal_offset + 2
          config_var = "rzConfig#{window_number}_#{tab_number}_#{terminal_number}"
          terminal_var = "rzTerminal#{window_number}_#{tab_number}_#{terminal_number}"
          append_configuration(lines, config_var, terminal, snapshot_dir, running_ids, duplicates)
          lines << "set #{terminal_var} to split #{terminal_vars.first} direction right with configuration #{config_var}"
          terminal_vars << terminal_var
        end

        title = tab.fetch("name", "")
        lines << "perform action #{applescript_string("set_tab_title:#{title}")} on #{terminal_vars.first}" unless title.empty?

        focused_offset = terminals.index { |terminal| terminal["focused"] } || 0
        final_focus = terminal_vars[focused_offset] if tab["selected"]
        selected_tab_var = tab_var if tab["selected"]
      end

      lines << "select tab #{selected_tab_var}" if selected_tab_var
      append_window_geometry(lines, window)
    end

    lines << "focus #{final_focus}" if final_focus
    lines << "end tell"
    [lines.join("\n"), duplicates.uniq]
  end

  def append_window_geometry(lines, window)
    position = window["position"]
    size = window["size"]
    return unless position && size

    lines << 'tell application "System Events"'
    lines << 'tell process "Ghostty"'
    lines << "set size of front window to {#{Integer(size.fetch("width"))}, #{Integer(size.fetch("height"))}}"
    lines << "set position of front window to {#{Integer(position.fetch("x"))}, #{Integer(position.fetch("y"))}}"
    lines << "end tell"
    lines << "end tell"
  end

  def window_position(row)
    return unless row["window_x"] && row["window_y"]

    {"x" => row["window_x"], "y" => row["window_y"]}
  end

  def window_size(row)
    return unless row["window_width"] && row["window_height"]

    {"width" => row["window_width"], "height" => row["window_height"]}
  end

  def window_geometry?(row)
    row.values_at("window_x", "window_y", "window_width", "window_height").all?
  end

  def append_configuration(lines, variable, terminal, snapshot_dir, running_ids, duplicates)
    lines << "set #{variable} to new surface configuration"
    cwd = terminal.fetch("working_directory", @home)
    lines << "set initial working directory of #{variable} to #{applescript_string(cwd)}"
    lines << "set command of #{variable} to #{applescript_string(restore_command(terminal, snapshot_dir, running_ids, duplicates))}"
    lines << "set wait after command of #{variable} to true"
  end

  def restore_command(terminal, snapshot_dir, running_ids, duplicates)
    commands = []
    scrollback = terminal["scrollback_file"] && File.join(snapshot_dir, terminal["scrollback_file"])
    commands << "/bin/cat -- #{Shellwords.escape(scrollback)}" if scrollback && File.file?(scrollback)

    session_id = terminal["codex_session_id"]
    if session_id && !running_ids.include?(session_id)
      commands << "exec codex resume #{Shellwords.escape(session_id)}"
    else
      if session_id
        duplicates << session_id
        commands << "/usr/bin/printf '\\n[rz] Codex session already running: %s\\n' #{Shellwords.escape(session_id)}"
      end
      commands << "exec /bin/zsh -l"
    end

    "/bin/zsh -lc #{Shellwords.escape(commands.join("; "))}"
  end

  def applescript_string(value)
    escaped = value.to_s.gsub("\\") { "\\\\" }.gsub('"', '\\"').gsub("\r", " ").gsub("\n", " ")
    %Q{"#{escaped}"}
  end

  def run_command(*command)
    output, status = Open3.capture2e(*command)
    raise "#{command.first} failed: #{output.strip}" unless status.success?

    output.strip
  end
end

Rz.new(ARGV).run if $PROGRAM_NAME == __FILE__
